{
  "name": "crimson-forge-ops",
  "version": "0.3.0",
  "description": "Elara — AI ops assistant for CrimsonForgePro",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "briefing": "tsx --env-file=.env src/trigger-briefing.ts",
    "google-auth": "tsx --env-file=.env scripts/google-oauth-setup.ts"
  },
  "keywords": [
    "crimson-forge",
    "monitoring",
    "ops",
    "scheduler",
    "elara"
  ],
  "author": "Crimson Forge",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@sentry/node": "^10.40.0",
    "@slack/bolt": "^3.19.0",
    "@supabase/supabase-js": "^2.38.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "googleapis": "^140.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.2",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.8",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
