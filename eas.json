{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "projectRoot": "mobile",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "projectRoot": "mobile",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_OVERSEER_URL": "https://crimsonforge-overseer-production.up.railway.app"
      }
    },
    "production": {
      "projectRoot": "mobile",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_OVERSEER_URL": "https://crimsonforge-overseer-production.up.railway.app"
      }
    }
  }
}
