# ── Required (core monitoring) ────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
FRONTEND_URL=https://crimsonforge.pro
API_HEALTH_URL=https://api.crimsonforge.pro/health
SUPABASE_URL=https://...supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SENTRY_AUTH_TOKEN=...
SENTRY_ORG=crimson-forge
SENTRY_PROJECT=crimson-forge
RAILWAY_API_TOKEN=...
CF_PROJECT_ID=...
CF_SERVICE_ID=...

# ── Elara (AI agent — activate by adding this key) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Slack two-way bot ─────────────────────────────────────────────────────
# Set up at api.slack.com — enable Socket Mode, add app_mentions:read + chat:write + im:history scopes
# Create App-Level Token with connections:write scope for SLACK_APP_TOKEN
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ── Google Workspace ──────────────────────────────────────────────────────
# Run: npm run google-auth   (one-time OAuth setup)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=1//...
GOOGLE_CALENDAR_ID=primary
GOOGLE_DRIVE_FOLDER_ID=         # optional: scope to specific folder

# ── GitHub (read-only) ────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...            # Personal Access Token — repo:read scope only
GITHUB_OWNER=your-github-username
GITHUB_REPOS=crimson-forge,CrimsonForge-Overseer

# ── Twilio (SMS monitoring + P0 alerts) ───────────────────────────────────
TWILIO_ACCOUNT_SID=         # From Twilio Console > Account Info
TWILIO_AUTH_TOKEN=          # From Twilio Console > Account Info
TWILIO_FROM_NUMBER=         # Your Twilio phone number (E.164 format: +1XXXXXXXXXX)
CLUTCH_PHONE_NUMBER=        # Clutch's mobile number for P0 SMS alerts (E.164: +1XXXXXXXXXX)

# ── Slack two-way bot (check-in dispatcher) ────────────────────────────────
SLACK_FOUNDER_USER_ID=      # Clutch's Slack member ID (Settings > Profile > ... > Copy member ID)

# ── Config ────────────────────────────────────────────────────────────────
MORNING_BRIEFING_HOUR=10        # Matches Clutch's ~10am wake time
TIMEZONE=America/Detroit
SILENT_SHOP_THRESHOLD_DAYS=3
NODE_ENV=production
